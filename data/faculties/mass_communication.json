  "rag_sections": [
    {
      "section_id": "mass_communication_overview_001",
      "section_type": "overview",
      "title": {
        "en": "Mass Communication Overview",
        "ar": "نبذة عن كلية الإعلام"
      },
      "content": {
        "en": "The Faculty of Mass Communication is a four-year programme split into two phases: two general foundation years for broad media literacy followed by two specialisation years in the chosen department. It aims to produce media professionals combining journalistic integrity, creative production skill, and strategic communication.",
