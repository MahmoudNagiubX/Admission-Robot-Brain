  "overview": {
    "welcome_summary": {
      "en": "Welcome to the Faculty of Arts and Design, ECU’s creative faculty for design, cinema, visual arts, graphics, multimedia, and fashion.",
      "ar": "مرحباً بك في كلية الفنون والتصميم، كلية ECU الإبداعية للتصميم والسينما والفنون البصرية والجرافيك والملتيميديا والأزياء.",
      "source_url": "https://ecu.edu.eg/faculties/arts-and-design/"
    },
    "description": {
      "en": "The faculty blends artistic sensibility with technical production mastery across six departments after a shared first-year foundation.",
      "ar": "تمزج الكلية بين الحس الفني والتمكن التقني في الإنتاج عبر ستة أقسام بعد سنة تأسيسية مشتركة.",
      "source_url": "https://ecu.edu.eg/faculties/arts-and-design/"
    },
