LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=your_openai_api_key_here
MAIN_LLM_MODEL=gpt-5-mini

ENABLE_LLM_RAG=true
ENABLE_LLM_REGISTRATION_EXTRACTION=true
LLM_TIMEOUT_SECONDS=15

STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key_here
ENABLE_VOICE_INPUT=true
MICROPHONE_DEVICE_INDEX=
VOICE_RECORD_MODE=vad
VOICE_RECORD_SECONDS=7
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1
VOICE_CHUNK_MS=30
VOICE_START_TIMEOUT_SECONDS=8
VOICE_MAX_RECORD_SECONDS=15
VOICE_MIN_RECORD_SECONDS=0.4
VOICE_SILENCE_STOP_SECONDS=1.0
VOICE_ENERGY_THRESHOLD=500
VOICE_PRE_ROLL_MS=300

ENABLE_TTS=false
TTS_PROVIDER=edge
EDGE_TTS_VOICE_EN=en-US-ChristopherNeural
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_RATE=-10%
EDGE_TTS_RATE_AR=-3%
TTS_FALLBACK_PHRASE=Sorry, I had a small audio issue. Please ask me again.

AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here
AZURE_TTS_VOICE_EN=en-US-JennyNeural
AZURE_TTS_VOICE_AR=ar-EG-SalmaNeural
TTS_RATE=0%
