LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=your_openai_api_key_here
MAIN_LLM_MODEL=gpt-5-mini

ENABLE_LLM_RAG=true
ENABLE_LLM_REGISTRATION_EXTRACTION=true
LLM_TIMEOUT_SECONDS=15

DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
SPEECHMATICS_API_KEY=
GLADIA_API_KEY=

ENABLE_TTS=true
TTS_PROVIDER=edge

EDGE_TTS_VOICE_EN=en-US-ChristopherNeural
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_RATE=-10%
EDGE_TTS_RATE_AR=-3%

STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
ENABLE_VOICE_INPUT=true

VOICE_RECORD_MODE=vad
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1
VOICE_CHUNK_MS=30
VOICE_START_TIMEOUT_SECONDS=8
VOICE_MAX_RECORD_SECONDS=15
VOICE_MIN_RECORD_SECONDS=0.4
VOICE_SILENCE_STOP_SECONDS=1.5 # Adjust this based on how long of a pause you want to allow before considering the user has stopped speaking
VOICE_ENERGY_THRESHOLD=500 # Adjust this threshold based on your Background noise level
VOICE_PRE_ROLL_MS=300