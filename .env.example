# Admission Robot AI Brain environment template.
# Do not put real keys in this file.

# LLM provider for optional grounded answer rewriting and registration cleanup.
# Supported: groq, openai
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
MAIN_LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=15
ENABLE_LLM_RAG=true
ENABLE_LLM_REGISTRATION_EXTRACTION=true

# Speech-to-text for local CLI voice demos only.
# Service-layer integration should pass transcripts directly.
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
ENABLE_VOICE_INPUT=true
MICROPHONE_DEVICE_INDEX=
VOICE_RECORD_MODE=vad
VOICE_RECORD_SECONDS=7
VOICE_SAMPLE_RATE=16000
VOICE_CHANNELS=1
VOICE_CHUNK_MS=30
VOICE_START_TIMEOUT_SECONDS=8
VOICE_MAX_RECORD_SECONDS=15
VOICE_MIN_RECORD_SECONDS=0.4
VOICE_SILENCE_STOP_SECONDS=1.0
VOICE_ENERGY_THRESHOLD=500
VOICE_PRE_ROLL_MS=300

# Text-to-speech for local CLI playback and optional service audio files.
# Service methods never play audio.
ENABLE_TTS=false
TTS_PROVIDER=edge
EDGE_TTS_VOICE_EN=en-US-ChristopherNeural
EDGE_TTS_VOICE_AR=ar-EG-SalmaNeural
EDGE_TTS_RATE=-10%
EDGE_TTS_RATE_AR=-3%
TTS_FALLBACK_PHRASE=Sorry, I had a small audio issue. Please ask me again.

# Legacy Azure speech settings are read by config.py only for compatibility.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TTS_VOICE_EN=en-US-JennyNeural
AZURE_TTS_VOICE_AR=ar-EG-SalmaNeural
TTS_RATE=0%

# Optional terminal display fix for Arabic text in local CLI.
ENABLE_ARABIC_TERMINAL_FIX=false
